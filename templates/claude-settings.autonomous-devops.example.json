{
  "$comment": "Example Claude Code permissions for operator-approved autonomous Hermes DevOps. Review carefully before installing. This grants one managed gateway restart and limited log cleanup.",
  "permissions": {
    "allow": [
      "Bash(hermes status)",
      "Bash(hermes doctor)",
      "Bash(hermes version)",
      "Bash(hermes --version)",
      "Bash(hermes gateway status)",
      "Bash(hermes cron list)",
      "Bash(hermes logs --since *)",
      "Bash(hermes logs errors --since *)",
      "Bash(ps -eo pid,cmd --sort=pid *)",
      "Bash(df -h)",
      "Bash(df -i)",
      "Bash(free -h)",
      "Bash(uptime)",
      "Bash(journalctl --disk-usage)",
      "Read()",
      "Bash(hermes gateway restart)",
      "Bash(journalctl --vacuum-time=14d)",
      "Bash(journalctl --vacuum-size=1G)",
      "Bash(ps aux --sort=-%mem *)",
      "Bash(ps aux --sort=-%cpu *)"
    ],
    "ask": [
      "Bash(hermes update*)",
      "Bash(hermes setup*)",
      "Bash(hermes model*)",
      "Bash(hermes login*)",
      "Bash(hermes logout*)",
      "Bash(hermes auth*)",
      "Bash(hermes config*)",
      "Bash(hermes cron create*)",
      "Bash(hermes cron update*)",
      "Bash(hermes cron remove*)",
      "Bash(hermes webhook*)",
      "Bash(hermes mcp*)",
      "Bash(apt *)",
      "Bash(apt-get *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(systemctl enable *)",
      "Bash(systemctl disable *)",
      "Bash(systemctl --user enable *)",
      "Bash(systemctl --user disable *)",
      "Bash(loginctl *)"
    ],
    "deny": [
      "Read(/opt/data/.env)",
      "Read(/opt/data/auth.json)",
      "Read(/opt/data/config.yaml)",
      "Read(**/*token*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(trash *)",
      "Bash(shred *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(killall *)",
      "Bash(systemctl restart ssh)",
      "Bash(systemctl restart sshd)",
      "Bash(ufw *)",
      "Bash(iptables *)",
      "Bash(nft *)",
      "Bash(reboot)",
      "Bash(shutdown *)"
    ]
  }
}
